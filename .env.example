# =============================================================================
# Power BI Embedded Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Azure AD / Service Principal Credentials
# -----------------------------------------------------------------------------
# These are obtained when you register an app in Azure AD
# See README.md for detailed instructions

# Application (client) ID from Azure AD App Registration
CLIENT_ID=your-client-id-guid-here

# Client secret value (not the secret ID)
# Generate this in Azure AD > App Registrations > Your App > Certificates & secrets
CLIENT_SECRET=your-client-secret-here

# Directory (tenant) ID from Azure AD
TENANT_ID=your-tenant-id-guid-here

# -----------------------------------------------------------------------------
# Power BI Configuration
# -----------------------------------------------------------------------------

# Workspace (Group) ID
# Find this in Power BI Service: Workspace settings > Copy the GUID from URL
# URL format: https://app.powerbi.com/groups/{WORKSPACE_ID}/...
WORKSPACE_ID=your-workspace-id-guid-here

# Report ID
# Find this in Power BI Service: Open the report > Copy the GUID from URL
# URL format: https://app.powerbi.com/groups/{workspace}/reports/{REPORT_ID}/...
REPORT_ID=your-report-id-guid-here

# Dataset ID (Optional)
# Usually not required unless using Row-Level Security (RLS)
# Find this in dataset settings or from the report's dataset
DATASET_ID=

# Filter target in your Power BI model
# IMPORTANT: Use exact table/column names from Model view in Power BI Desktop
FILTER_TABLE_NAME=Sales
FILTER_TABLE_CANDIDATES=Sales,SalesForecast
FILTER_COLUMN_NAME=Product

# -----------------------------------------------------------------------------
# Flask Configuration (Optional)
# -----------------------------------------------------------------------------

# Secret key for Flask sessions (change in production)
FLASK_SECRET_KEY=change-this-to-a-random-secret-key

# Enable debug mode (set to False in production)
FLASK_DEBUG=True
